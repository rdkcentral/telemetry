{
    "files.exclude": {
        // Autotools generated scripts and auxiliary files
        "aclocal.m4": true,
        "autom4te.cache": true,
        "compile": true,
        "config.guess": true,
        "config.log": true,
        "config.status": true,
        "config.sub": true,
        "configure": true,
        "depcomp": true,
        "install-sh": true,
        "libtool": true,
        "ltmain.sh": true,
        "missing": true,

        // Makefiles generated by automake/configure (source is Makefile.am)
        "**/Makefile": true,
        "**/Makefile.in": true,

        // Libtool and compiler build artifacts
        "**/.deps": true,
        "**/.libs": true,
        "**/*.la": true,
        "**/*.lo": true,
        "**/*.o": true,

        // Compiled binaries
        "source/telemetry2_0": true,
        "source/commonlib/telemetry2_0_client": true,

        // Shared certificates
        "shared_certs": true
    }
}
